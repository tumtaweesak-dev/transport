    text-overflow: ellipsis;
    white-space: nowrap;
}

.module-icon {
    width: 16px;
    color: var(--accent-primary);
    font-size: 0.82rem;
    text-align: center;
    flex: 0 0 16px;
}

.nav-module-title:hover {
    color: var(--accent-secondary);
    background: rgba(255, 255, 255, 0.04);
}

.nav-sub-menu {
    gap: 4px;
}

.nav-btn {
    min-height: 42px;
