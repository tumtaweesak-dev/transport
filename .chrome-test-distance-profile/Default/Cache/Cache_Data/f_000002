.section-subtitle i,
.text-accent {
    color: var(--accent-primary);
}

.stats-grid {
    gap: 16px;
    margin-bottom: 18px;
}

.stat-card {
    min-height: 104px;
    padding: 18px;
    background: rgba(31, 36, 43, 0.72);
    border: 1px solid var(--glass-border);
    border-radius: var(--border-radius-md);
    box-shadow: none;
}

.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.24);
}

.stat-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--border-radius-md);
}

.stat-info h4 {
    color: var(--text-secondary);
    font-size: 0.84rem;
}

.stat-value {
    color: var(--text-primary);
    font-size: 1.55rem;
    letter-spacing: 0;
}

.dashboard-middle-grid,
.dashboard-bottom-grid,
.dashboard-content-layout {
    gap: 16px;
}

.dynamic-form {
    max-width: 1120px;
}

input, select, textarea {
    min-height: 42px;
    background: rgba(12, 14, 16, 0.54);
    border-color: rgba(255, 255, 255, 0.11);
    border-radius: var(--border-radius-md);
    color: var(--text-primary);
    font-size: 0.94rem;
}

input::placeholder, textarea::placeholder {
    color: rgba(168, 176, 188, 0.55);
    font-style: normal;
}

input:focus, select:focus, textarea:focus {
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(201, 164, 76, 0.16);
    background: rgba(12, 14, 16, 0.78);
}

input[readonly] {
    color: var(--text-secondary);
    cursor: default;
    background: rgba(255, 255, 255, 0.045);
}

.input-group label {
    color: var(--text-secondary);
    font-size: 0.82rem;
}

.btn {
    min-height: 40px;
    border-radius: var(--border-radius-md);
    font-size: 0.92rem;
    letter-spacing: 0;
}

.btn-primary {
    background: #e6d39d;
    color: #161616;
    box-shadow: 0 10px 24px rgba(201, 164, 76, 0.18);
}

.btn-primary:hover {
    background: #f0dfad;
    transform: translateY(-1px);
    box-shadow: 0 14px 30px rgba(201, 164, 76, 0.26);
}

.btn-secondary {
    background: var(--surface-2);
    border-color: var(--glass-border);
    color: var(--text-primary);
}

.btn-secondary:hover {
    background: var(--surface-3);
    border-color: rgba(228, 201, 120, 0.42);
    color: var(--accent-secondary);
}

.btn-icon {
    border-radius: var(--border-radius-sm);
}

.table-container {
    background: rgba(15, 17, 20, 0.56);
    border-color: var(--glass-border);
}

.modern-table th {
    background: rgba(255, 255, 255, 0.045);
    color: var(--text-secondary);
    font-size: 0.78rem;
    letter-spacing: 0;
}

.modern-table td {
    color: var(--text-primary);
    border-bottom-color: rgba(255, 255, 255, 0.06);
}

.modern-table tr:hover td {
    background: rgba(255, 255, 255, 0.025);
}

.modal-overlay {
    background: rgba(6, 7, 8, 0.72);
}

.modal-content {
    background: var(--surface-1);
}

.summary-box {
    background: rgba(93, 143, 215, 0.11);
    border-left-color: var(--accent-blue);
}

.step.active .step-icon {
    border-color: var(--accent-primary);
    background: rgba(201, 164, 76, 0.16);
    box-shadow: 0 0 0 4px rgba(201, 164, 76, 0.1);
}

.step.completed .step-icon {
    background: var(--accent-green);
    border-color: var(--accent-green);
}

.text-primary-gradient {
    background: none;
    -webkit-text-fill-color: currentColor;
    color: var(--accent-secondary);
}

@media (min-width: 901px) {
    .main-content {
        width: calc(100% - var(--sidebar-width) - 18px);
    }
}

@media (max-width: 900px) {
    .app-container {
        flex-direction: column;
        padding: 12px;
        gap: 12px;
    }

    .sidebar {
        position: relative;
        top: auto;
        width: 100%;
        height: auto;
        max-height: 430px;
        padding: 16px;
    }

    .sidebar-header {
        margin-bottom: 10px;
        padding-bottom: 12px;
    }

    .sidebar-nav {
        height: auto;
        max-height: 320px;
        flex-direction: column;
        align-items: stretch;
        gap: 12px;
        overflow-x: hidden;
        overflow-y: auto;
        padding: 0 6px 2px 0;
    }

    .nav-module {
        min-width: 0;
        flex: none;
    }

    .nav-sub-menu {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 6px;
    }

    .nav-btn {
        min-height: 48px;
        align-items: flex-start;
    }

    .top-header {
        min-height: 64px;
        padding: 14px 16px;
    }

    .view-section {
        padding: 18px;
    }

    .dashboard-middle-grid,
    .dashboard-bottom-grid,
    .dashboard-content-layout {
        grid-template-columns: 1fr !important;
    }

    .stats-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@media (max-width: 560px) {
    .app-container {
        padding: 8px;
    }

    .stats-grid {
        grid-template-columns: 1fr;
    }

    .nav-sub-menu {
        grid-template-columns: 1fr;
    }

    .form-row.split-row,
    .input-with-action,
    .flex-between {
        flex-direction: column;
        align-items: stretch;
    }

    .btn {
        width: 100%;
    }
}
