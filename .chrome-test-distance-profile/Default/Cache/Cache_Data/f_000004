                lat1 = prevInput.dataset.lat;
                lng1 = prevInput.dataset.lng;
                startName = prevInput.value || `ปลายทางที่ ${index}`;
            }
            
            const originalHtml = btnCheckRoute.innerHTML;
            btnCheckRoute.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            btnCheckRoute.disabled = true;
            
            const endName = currentInput.value || `ปลายทางที่ ${index + 1}`;
            
            fetch(`https://router.project-osrm.org/route/v1/driving/${lng1},${lat1};${lng2},${lat2}?overview=false&alternatives=true`)
                .then(res => res.json())
                .then(data => {
                    if (data.code === 'Ok' && data.routes && data.routes.length > 0) {
                        // Find the route with the shortest distance (in case alternatives exist)
                        let shortestRoute = data.routes[0];
                        for(let r of data.routes) {
                            if(r.distance < shortestRoute.distance) {
                                shortestRoute = r;
                            }
                        }
                        
                        const distanceMeters = shortestRoute.distance;
                        const distanceKm = (distanceMeters / 1000).toFixed(2);
                        if (distanceInput) {
                            distanceInput.value = distanceKm;
                            distanceInput.dispatchEvent(new Event('input', { bubbles: true }));
                            
                            addTerminalLog(`คำนวณระยะทาง: ${startName} -> ${endName} = ${distanceKm} กม.`, 'info');
                        }
                    } else {
                        alert('ไม่พบเส้นทางที่รถยนต์สามารถเดินทางได้');
