<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transport Management System</title>
    <link rel="stylesheet" href="css/styles.css?v=3">
    <!-- Using Google Fonts: Inter & Playfair Display -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Leaflet JS for Maps (Local Offline Version) -->
    <link rel="stylesheet" href="map/leaflet.css">
    <script src="map/leaflet.js"></script>

    <!-- Map Plugins (Geocoder, Locate, Fullscreen) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet.locatecontrol@0.79.0/dist/L.Control.Locate.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/leaflet.locatecontrol@0.79.0/dist/L.Control.Locate.min.js" charset="utf-8"></script>
    <link href='https://api.mapbox.com/mapbox.js/plugins/leaflet-fullscreen/v1.0.1/leaflet.fullscreen.css' rel='stylesheet' />
    <script src='https://api.mapbox.com/mapbox.js/plugins/leaflet-fullscreen/v1.0.1/Leaflet.fullscreen.min.js'></script>
    
    <!-- Leaflet Routing Machine for drawing paths -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.css" />
    <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.js"></script>
    <!-- QR Code Generator Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar glass-panel">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fa-solid fa-truck-fast"></i>
                    <h2>TMS Pro</h2>
                </div>
            </div>
            <nav class="sidebar-nav">
                <!-- 1. Dashboard (Control Tower) -->
                <div class="nav-module">
                    <div class="nav-module-title"><span><i class="fa-solid fa-tower-broadcast module-icon"></i> 1. ศูนย์ควบคุม (Control Tower)</span> <i class="fa-solid fa-chevron-down chevron"></i></div>
                    <div class="nav-sub-menu">
                        <button class="nav-btn active" data-target="dashboard">
                            <i class="fa-solid fa-chart-line"></i>
                            แดชบอร์ดภาพรวม (Dashboard)
                        </button>
                    </div>
                </div>

                <!-- 2. Travel Plan -->
                <div class="nav-module">
                    <div class="nav-module-title"><span><i class="fa-solid fa-route module-icon"></i> 2. แผนการเดินทาง (Travel Plan)</span> <i class="fa-solid fa-chevron-down chevron"></i></div>
                    <div class="nav-sub-menu">
                        <button class="nav-btn" data-target="travel-plan">
                            <i class="fa-solid fa-map-location-dot"></i>
                            วางแผนการเดินทาง (Shipment Planning)
                        </button>
                        <button class="nav-btn" data-target="manager-approval">
                            <i class="fa-solid fa-user-tie"></i>
                            อนุมัติโดยหัวหน้า (Mgr Approval)
                        </button>
                        <button class="nav-btn" data-target="hr-approval">
                            <i class="fa-solid fa-users-gear"></i>
                            ตรวจสอบโดย HR (HR Check)
                        </button>
                        <button class="nav-btn" data-target="md-approval">
                            <i class="fa-solid fa-user-tie"></i>
                            อนุมัติโดย MD (MD Approval)
                        </button>
                        <button class="nav-btn" data-target="accounting-approval">
                            <i class="fa-solid fa-file-invoice-dollar"></i>
                            พนักงานบัญชีทำจ่าย (Accounting)
                        </button>
                    </div>
                </div>

                <!-- 3. Transport Planning -->
                <div class="nav-module">
                    <div class="nav-module-title"><span><i class="fa-solid fa-truck-ramp-box module-icon"></i> 3. แผนการขนส่ง (Transport Planning)</span> <i class="fa-solid fa-chevron-down chevron"></i></div>
                    <div class="nav-sub-menu">
                        <button class="nav-btn" data-target="car-booking">
                            <i class="fa-solid fa-calendar-check"></i>
                            จองรถ (Car Booking)
                        </button>
                        <button class="nav-btn" data-target="route-optimization">
                            <i class="fa-solid fa-route"></i>
                            จัดการเส้นทางเดินรถ (Route Optimization)
                        </button>
                        <button class="nav-btn" data-target="car-arrangement">
                            <i class="fa-solid fa-truck-ramp-box"></i>
                            จัดรถ (Car Arrangement)
                        </button>
                        <button class="nav-btn" data-target="packing">
                            <i class="fa-solid fa-box-open"></i>
                            จัดเรียงสินค้า (Load Planning)
                        </button>
                        <button class="nav-btn" data-target="delivery-scheduling">
                            <i class="fa-solid fa-clock"></i>
                            ตารางเวลาส่งมอบ (Delivery Scheduling)
                        </button>
                    </div>
                </div>

                <!-- 4. Fleet Management -->
                <div class="nav-module">
                    <div class="nav-module-title"><span><i class="fa-solid fa-warehouse module-icon"></i> 4. จัดการยานพาหนะ (Fleet Management)</span> <i class="fa-solid fa-chevron-down chevron"></i></div>
                    <div class="nav-sub-menu">
                        <button class="nav-btn" data-target="admin-settings">
                            <i class="fa-solid fa-truck"></i>
                            ข้อมูลรถ (Vehicle Registry)
                        </button>
                        <button class="nav-btn" data-target="maintenance">
                            <i class="fa-solid fa-wrench"></i>
                            ตารางซ่อมบำรุง (Maintenance)
                        </button>
                        <button class="nav-btn" data-target="fuel">
                            <i class="fa-solid fa-gas-pump"></i>
                            จัดการค่าน้ำมัน (Fuel Management)
                        </button>
                    </div>
                </div>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <header class="top-header glass-panel">
                <h1 id="page-title"><i class="fa-solid fa-chart-line"></i> แดชบอร์ด (Dashboard)</h1>
                <div class="user-profile">
                    <div class="avatar">
                        <i class="fa-solid fa-user"></i>
                    </div>
                </div>
            </header>

            <div class="content-wrapper">
                <!-- Flow: Dashboard -->
                <section id="dashboard" class="view-section active glass-panel">
                    <h3 class="section-subtitle"><i class="fa-solid fa-chart-line text-accent"></i> ภาพรวมการขนส่ง (Transportation Overview)</h3>
                    
                    <!-- Top Stats -->
                    <div class="stats-grid">
                        <div class="stat-card glass-panel-inner">
                            <div class="stat-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.1);"><i class="fa-solid fa-truck-fast"></i></div>
                            <div class="stat-info">
                                <h4>กำลังเดินทาง</h4>
                                <div class="stat-value" id="stat-traveling">3 คัน</div>
                            </div>
                        </div>
                        <div class="stat-card glass-panel-inner">
                            <div class="stat-icon" style="color: #10b981; background: rgba(16, 185, 129, 0.1);"><i class="fa-solid fa-check-circle"></i></div>
                            <div class="stat-info">
                                <h4>ถึงเป้าหมายแล้ววันนี้</h4>
                                <div class="stat-value" id="stat-arrived">12 ขบวน</div>
                            </div>
                        </div>
                        <div class="stat-card glass-panel-inner">
                            <div class="stat-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.1);"><i class="fa-solid fa-clock"></i></div>
                            <div class="stat-info">
                                <h4>เตรียมเดินทาง</h4>
                                <div class="stat-value" id="stat-preparing">5 คัน</div>
                            </div>
                        </div>
                        <div class="stat-card glass-panel-inner">
                            <div class="stat-icon" style="color: #8b5cf6; background: rgba(139, 92, 246, 0.1);"><i class="fa-solid fa-bed"></i></div>
                            <div class="stat-info">
                                <h4>กำลังจอดพัก / หลับ</h4>
                                <div class="stat-value" id="stat-resting">1 คัน</div>
                            </div>
                        </div>
                    </div>

                    <div class="dashboard-content-layout mt-4">
                        <!-- Left Sidebar: Fuel Prices -->
                        <div class="glass-panel-inner" style="padding: 1.5rem; display: flex; flex-direction: column; align-items: center;">
                            <h4 style="margin-bottom: 1.5rem; width: 100%; text-align: left;"><i class="fa-solid fa-gas-pump text-accent"></i> ราคาน้ำมัน (บางจาก)</h4>
                            <div style="width: 320px; overflow: hidden; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
                                <iframe width="100%" height="875" src="https://oil-price.bangchak.co.th/BcpOilPrice1/th" frameborder="0" scrolling="no"></iframe>
                            </div>
                            <div id="dashboard-fuel-price-table" class="fuel-price-panel mt-4"></div>
                        </div>

                        <!-- Right Main Content -->
                        <div style="display: flex; flex-direction: column; gap: 1.5rem; min-width: 0;">
                            <!-- Control Tower KPIs & Alerts -->
                            <div class="dashboard-middle-grid" style="margin-bottom: 0;">
                                <div class="glass-panel-inner">
                                    <h4><i class="fa-solid fa-gauge-high text-accent"></i> KPI Snapshot (Performance)</h4>
                                    <div class="stats-grid mt-3" style="grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));">
                                        <div class="stat-card" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); padding: 15px; border-radius: 8px;">
                                            <h5 class="text-secondary" style="font-size: 0.85rem; font-weight: 500;">On-Time Delivery</h5>
                                            <h2 class="text-primary-gradient mt-1" style="font-size: 1.8rem; font-weight: 700;">94.5%</h2>
                                            <div style="font-size: 0.75rem; color: #10b981; margin-top: 5px;"><i class="fa-solid fa-arrow-trend-up"></i> +2.4% vs last week</div>
                                        </div>
                                        <div class="stat-card" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); padding: 15px; border-radius: 8px;">
                                            <h5 class="text-secondary" style="font-size: 0.85rem; font-weight: 500;">Fleet Utilization</h5>
                                            <h2 class="text-primary-gradient mt-1" style="font-size: 1.8rem; font-weight: 700;">82%</h2>
                                            <div style="font-size: 0.75rem; color: #10b981; margin-top: 5px;"><i class="fa-solid fa-arrow-trend-up"></i> Optimal</div>
                                        </div>
                                        <div class="stat-card" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); padding: 15px; border-radius: 8px;">
                                            <h5 class="text-secondary" style="font-size: 0.85rem; font-weight: 500;">Avg Cost / Trip</h5>
                                            <h2 class="text-primary-gradient mt-1" style="font-size: 1.8rem; font-weight: 700;">฿1,250</h2>
                                            <div style="font-size: 0.75rem; color: #ef4444; margin-top: 5px;"><i class="fa-solid fa-arrow-trend-down"></i> -1.5% vs budget</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="glass-panel-inner" style="border-left: 3px solid #ef4444;">
                                    <div class="flex-between">
                                        <h4><i class="fa-solid fa-bell text-danger"></i> Alerts & Exceptions</h4>
                                        <span class="badge" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem;">2 Active</span>
                                    </div>
                                    <ul class="mt-3" style="list-style: none; padding: 0;">
                                        <li style="padding: 10px; background: rgba(239, 68, 68, 0.1); border-radius: 6px; margin-bottom: 8px; font-size: 0.85rem; display: flex; align-items: flex-start; gap: 10px;">
                                            <i class="fa-solid fa-triangle-exclamation text-danger mt-1"></i>
                                            <div><strong>ทะเบียน กท 1234</strong><br><span class="text-secondary">Expected delay: 45 min due to heavy traffic (Rama II Rd)</span></div>
                                        </li>
                                        <li style="padding: 10px; background: rgba(245, 158, 11, 0.1); border-radius: 6px; margin-bottom: 0; font-size: 0.85rem; display: flex; align-items: flex-start; gap: 10px;">
                                            <i class="fa-solid fa-wrench mt-1" style="color: #f59e0b;"></i>
                                            <div><strong>ทะเบียน ชร 9999</strong><br><span class="text-secondary">Maintenance overdue by 3 days. Action required.</span></div>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <!-- Middle: Map and Charts -->
                            <div class="dashboard-middle-grid" style="margin-bottom: 0;">
                                <!-- Live Map Tracker -->
                                <div class="map-tracker-container glass-panel-inner">
                                    <h4><i class="fa-solid fa-location-crosshairs text-accent"></i> แผนที่จำลองพิกัดรถปัจจุบัน (Live Tracker)</h4>
                                    <div id="dashboard-live-map" style="height: 350px; border-radius: 8px; margin-top: 15px; border: 1px solid rgba(255,255,255,0.1); z-index: 1;"></div>
                                    <small class="text-secondary mt-2" style="display:block;"><i class="fa-solid fa-map-pin"></i> พิกัดอัปเดตจาก GPS จริง (จำลองการเคลื่อนที่แบบเรียลไทม์)</small>
                                </div>

                                <!-- Pie Chart -->
                                <div class="charts-container glass-panel-inner">
                                     <h4><i class="fa-solid fa-chart-pie text-accent"></i> สัดส่วนสถานะงานวันนี้</h4>
                                     <div class="chart-wrapper">
                                         <canvas id="statusPieChart"></canvas>
                                     </div>
                                </div>
                            </div>
                            
                            <!-- Bottom: Bar Chart & Table -->
                            <div class="dashboard-bottom-grid">
                                <div class="glass-panel-inner chart-panel">
                                    <h4><i class="fa-solid fa-chart-column text-accent"></i> สถิติปริมาณงานขนส่ง (แนวตั้ง)</h4>
                                    <div class="chart-wrapper-bar">
                                         <canvas id="usageBarChart"></canvas>
                                    </div>
                                </div>
                                
                                <div class="glass-panel-inner table-panel">
                                    <h4><i class="fa-solid fa-list-check text-accent"></i> สถานะรถปัจจุบัน (Active Vehicles)</h4>
                                    <div class="table-responsive">
                                        <table class="table table-hover">
                                            <thead>
                                                <tr>
                                                    <th>ทะเบียนรถ</th>
                                                    <th>คนขับ</th>
                                                    <th>ผู้จอง</th>
                                                    <th>เส้นทาง</th>
                                                    <th>สถานะ</th>
                                                </tr>
                                            </thead>
                                            <tbody id="dashboard-vehicles-table">
                                                <!-- Populated via script -->
                                            </tbody>
                                        </table>
                                        <small class="text-secondary mt-2" style="display:block;"><i class="fa-solid fa-hand-pointer"></i> * ดับเบิ้ลคลิกแถวเพื่อดูหน้าต่างป๊อปอัพรายละเอียด (Modal)</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Flow 1: Travel Plan -->
                <section id="travel-plan" class="view-section glass-panel">
                    <form class="dynamic-form" id="form-travel-plan" onsubmit="event.preventDefault();">
                        
                        <!-- 1. Traveler Details -->
                        <h3 class="section-subtitle">ข้อมูลผู้เดินทาง</h3>
                        <div id="travelers-list">
                            <!-- Traveler Row 1 -->
                            <div class="traveler-card glass-panel-inner mb-3">
                                <div class="card-header flex-between">
                                    <h4><i class="fa-solid fa-user"></i> ผู้เดินทางคนที่ 1</h4>
                                </div>
                                <div class="form-row split-row mt-3">
                                    <div class="input-group">
                                        <label>รหัสพนักงาน</label>
                                        <input type="text" placeholder="ระบุรหัสพนักงาน" required>
                                    </div>
                                    <div class="input-group">
                                        <label>ชื่อ - นามสกุล</label>
                                        <input type="text" placeholder="ระบุชื่อและนามสกุล" required>
                                    </div>
                                </div>
                                <div class="form-row split-row mt-3">
                                    <div class="input-group">
                                        <label>แผนก</label>
                                        <input type="text" placeholder="ระบุแผนก" required>
                                    </div>
                                    <div class="input-group">
                                        <label>ตำแหน่ง</label>
                                        <input type="text" placeholder="ระบุตำแหน่ง" required>
                                    </div>
                                </div>
                                <div class="form-row split-row mt-3">
                                    <div class="input-group">
                                        <label>เบอร์โทรศัพท์</label>
                                        <input type="tel" placeholder="08X-XXX-XXXX" required>
                                    </div>
                                    <div class="input-group">
                                        <label>รายละเอียดการเดินทาง (Comment)</label>
                                        <input type="text" placeholder="ระบุรายละเอียดเพิ่มเติม">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="btn btn-secondary btn-sm" id="btn-add-traveler">
                            <i class="fa-solid fa-user-plus"></i> เพิ่มผู้เดินทาง
                        </button>

                        <!-- 2. Site / Route Details -->
                        <h3 class="section-subtitle mt-5">เส้นทาง (ต้นทาง - ปลายทาง)</h3>
                        
                        <!-- Origin -->
                        <div class="site-card glass-panel-inner mb-3 origin-site">
                            <div class="card-header">
                                <h4><i class="fa-solid fa-location-dot text-accent"></i> ต้นทาง</h4>
                            </div>
                            <div class="form-row split-row mt-3">
                                <div class="input-group">
                                    <label>รหัสโครงการ</label>
                                    <input type="text" placeholder="ระบุรหัส" required>
                                </div>
                                <div class="input-group">
                                    <label>ชื่อโครงการ / สถานที่</label>
                                    <input type="text" placeholder="ระบุชื่อสถานที่" required>
                                </div>
                            </div>
                            <div class="form-row mt-3">
                                <div class="input-group">
                                    <label><i class="fa-brands fa-google"></i> Google Map Link หรือ พิกัด</label>
                                    <div class="input-with-action">
                                        <input type="text" class="map-link-input" placeholder="คลิกปุ่มเพื่อเลือกสถานที่" readonly required>
                                        <button type="button" class="btn-icon text-accent btn-open-map" title="เลือกจากแผนที่"><i class="fa-solid fa-map-location-dot"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Destinations Container -->
                        <div id="destinations-list">
                            <!-- Dest 1 -->
                            <div class="site-card glass-panel-inner mb-3 dest-site">
                                <div class="card-header flex-between">
                                    <h4><i class="fa-solid fa-flag-checkered text-accent"></i> ปลายทางที่ 1</h4>
                                </div>
                                <div class="form-row split-row mt-3">
                                    <div class="input-group">
                                        <label>รหัสโครงการ</label>
                                        <input type="text" placeholder="ระบุรหัส" required>
                                    </div>
                                    <div class="input-group">
                                        <label>ชื่อโครงการ / สถานที่</label>
                                        <input type="text" placeholder="ระบุชื่อสถานที่" required>
                                    </div>
                                </div>
                                <div class="form-row mt-3">
                                    <div class="input-group">
                                        <label><i class="fa-brands fa-google"></i> Google Map Link หรือ พิกัด</label>
                                        <div class="input-with-action">
                                            <input type="text" class="map-link-input" placeholder="คลิกปุ่มเพื่อเลือกสถานที่" readonly required>
                                            <button type="button" class="btn-icon text-accent btn-open-map" title="เลือกจากแผนที่"><i class="fa-solid fa-map-location-dot"></i></button>
                                            <button type="button" class="btn-icon text-accent btn-check-route" title="เช็คระยะทาง"><i class="fa-solid fa-route"></i></button>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-row split-row mt-3">
                                    <div class="input-group">
                                        <label>ระยะทางจากจุดก่อนหน้า (กม.)</label>
                                        <input type="number" class="distance-input" placeholder="0.00" min="0" step="0.1" required>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="btn btn-secondary btn-sm" id="btn-add-destination">
                            <i class="fa-solid fa-plus"></i> เพิ่มจุดหมายปลายทาง
                        </button>
                        
                        <div class="summary-box mt-3 mb-4">
                            <strong>รวมระยะทางทั้งหมด: </strong>
                            <span id="total-distance" class="text-accent text-lg">0.00</span> กม.
                        </div>

                        <!-- Date / Time -->
                        <div class="form-row split-row mt-4">
                            <div class="input-group">
                                <label><i class="fa-regular fa-calendar"></i> วันที่เดินทาง</label>
                                <input type="date" required>
                            </div>
                            <div class="input-group">
                                <label><i class="fa-regular fa-clock"></i> เวลาที่เดินทาง</label>
                                <input type="time" required>
                            </div>
                        </div>

                        <!-- 3. Professional Live Tracking Control Center -->
                        <div class="flex-between">
                            <h3 class="section-subtitle mt-5">ศูนย์ควบคุมการติดตาม (Live Tracking Control Center)</h3>
                            <div style="position: relative; display: inline-block;">
                                <button type="button" class="btn btn-secondary btn-sm mt-5" id="btn-open-mobile-sync">
