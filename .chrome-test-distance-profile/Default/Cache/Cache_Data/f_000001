                        <div class="glass-panel-inner" style="display: flex; flex-direction: column; gap: 15px; max-height: 700px;">
                            <div class="input-group">
                                <label><i class="fa-solid fa-truck"></i> เลือกรถจัดส่ง (Select Truck)</label>
                                <select id="packing-truck-select">
                                    <option value="4W">รถกระบะ 4 ล้อ (ความจุ 1,500 kg)</option>
                                    <option value="6W" selected>รถบรรทุก 6 ล้อ (ความจุ 5,000 kg)</option>
                                    <option value="10W">รถบรรทุก 10 ล้อ (ความจุ 15,000 kg)</option>
                                </select>
                            </div>
                            
                            <hr style="border-color: rgba(255,255,255,0.1); margin: 5px 0;">
                            
                            <div class="flex-between">
                                <h4><i class="fa-solid fa-cubes text-accent"></i> สินค้ารอจัดเรียง</h4>
                                <span class="badge" style="background: rgba(249, 115, 22, 0.2); color: #f97316;" id="packing-unassigned-count">0 ชิ้น</span>
                            </div>
                            
                            <div id="cargo-pool-list" style="flex-grow: 1; overflow-y: auto; padding-right: 5px; display: flex; flex-direction: column; gap: 10px; min-height: 200px;">
                                <!-- Draggable items will be appended here -->
                            </div>
                            
                            <button type="button" class="btn btn-primary w-100 mt-auto" id="btn-auto-pack">
                                <i class="fa-solid fa-wand-magic-sparkles"></i> จัดเรียงอัตโนมัติ (Auto-Pack)
                            </button>
                        </div>

                        <!-- Right Panel: Truck Bed Visualization -->
                        <div class="glass-panel-inner" style="display: flex; flex-direction: column; gap: 15px;">
                            <div class="flex-between align-items-center mb-2">
                                <h4><i class="fa-solid fa-truck-moving text-accent"></i> พื้นที่ท้ายรถ (Truck Bed Simulation)</h4>
                                <button type="button" class="btn btn-secondary btn-sm" id="btn-reset-pack"><i class="fa-solid fa-rotate-left"></i> รีทิ้งทั้งหมด (Reset)</button>
                            </div>
                            
                            <div class="stat-card" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); padding: 15px; border-radius: 8px;">
                                <div class="flex-between mb-2">
                                    <span class="text-sm">น้ำหนักบรรทุก (Weight): <span id="packing-weight-text">0 / 0 kg</span></span>
                                    <strong id="packing-weight-percent" class="text-accent">0%</strong>
                                </div>
                                <div style="width: 100%; height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; margin-bottom: 15px;">
                                    <div id="packing-weight-bar" style="width: 0%; height: 100%; background: #f97316; transition: width 0.3s, background 0.3s;"></div>
                                </div>
                                
                                <div class="flex-between mb-2">
                                    <span class="text-sm">ปริมาตรและพื้นที่ (Volume): <span id="packing-vol-text">0 / 0 CBM</span></span>
                                    <strong id="packing-vol-percent" class="text-accent">0%</strong>
                                </div>
                                <div style="width: 100%; height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden;">
                                    <div id="packing-vol-bar" style="width: 0%; height: 100%; background: #3b82f6; transition: width 0.3s, background 0.3s;"></div>
                                </div>
                            </div>

                            <div id="truck-bed-container" 
                                 style="flex-grow: 1; background: repeating-linear-gradient(45deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 20px, rgba(255,255,255,0.05) 20px, rgba(255,255,255,0.05) 40px); border: 2px dashed rgba(255,255,255,0.2); border-radius: 8px; position: relative; min-height: 400px; display: flex; flex-wrap: wrap; align-content: flex-start; gap: 5px; padding: 10px; transition: border-color 0.3s; overflow-y: auto;">
                                <div id="truck-bed-placeholder" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: rgba(255,255,255,0.3); font-size: 1.2rem; pointer-events: none; text-align: center;">
                                    <i class="fa-solid fa-arrow-down fa-2x mb-2"></i><br>ลากกล่องสินค้ามาวางที่นี่
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section id="delivery-scheduling" class="view-section glass-panel">
                    <h3 class="section-subtitle"><i class="fa-solid fa-clock"></i> Delivery Scheduling</h3>
                    <div class="glass-panel-inner mt-4 p-5 text-center text-secondary">
                        <i class="fa-solid fa-calendar fa-3x mb-3" style="opacity: 0.5;"></i>
                        <h4>กำลังพัฒนาระบบตารางเวลา...</h4>
                        <p>ตารางส่งมอบงาน (Timeline & Chart) สำหรับวางแผนการจัดส่งล่วงหน้า</p>
                    </div>
                </section>

                <section id="import-orders" class="view-section glass-panel">
                    <h3 class="section-subtitle"><i class="fa-solid fa-file-import"></i> Create / Import Orders</h3>
                    <div class="glass-panel-inner mt-4 p-5 text-center text-secondary">
                        <i class="fa-solid fa-cloud-arrow-up fa-3x mb-3" style="opacity: 0.5;"></i>
                        <h4>กำลังพัฒนาการนำเข้าข้อมูลออเดอร์...</h4>
                        <p>ฟีเจอร์รองรับการอัปโหลดไฟล์ Excel/CSV หรือเชื่อมต่อ ERP สร้างรายการส่งของอัตโนมัติ</p>
                    </div>
                </section>

                <section id="shipment-tracking" class="view-section glass-panel">
                    <h3 class="section-subtitle"><i class="fa-solid fa-satellite-dish"></i> Shipment Tracking</h3>
                    <div class="glass-panel-inner mt-4 p-5 text-center text-secondary">
                        <i class="fa-solid fa-truck-fast fa-3x mb-3" style="opacity: 0.5;"></i>
                        <h4>กำลังพัฒนาระบบ Tracking ประวัติย้อนหลัง...</h4>
                        <p>ตรวจสอบหลักฐานการส่งมอบ (POD), ลายเซ็นต์ดิจิทัล และสถานะของทุกรายการ</p>
                    </div>
                </section>

                <section id="exceptions-handling" class="view-section glass-panel">
                    <h3 class="section-subtitle"><i class="fa-solid fa-triangle-exclamation text-danger"></i> Exceptions Handling</h3>
                    <div class="glass-panel-inner mt-4 p-5 text-center text-secondary">
                        <i class="fa-solid fa-circle-exclamation text-danger fa-3x mb-3" style="opacity: 0.5;"></i>
                        <h4>กำลังพัฒนาระบบจัดการข้อผิดพลาด...</h4>
                        <p>พิจารณาและจัดการเคสสินค้าเสียหาย, ส่งมอบไม่สำเร็จ หรืออุบัติเหตุระหว่างทาง</p>
                    </div>
                </section>

                <section id="maintenance" class="view-section glass-panel">
                    <h3 class="section-subtitle mb-4"><i class="fa-solid fa-wrench text-accent"></i> การบำรุงรักษายานพาหนะ (Maintenance Scheduling)</h3>
                    <div class="flex-between mb-4">
                        <p class="text-secondary">ติดตามและกำหนดการซ่อมบำรุงของฝูงรถ</p>
                        <button class="btn btn-primary btn-sm" id="btn-add-maintenance"><i class="fa-solid fa-plus"></i> บันทึกรายการใหม่</button>
                    </div>

                    <div class="table-container">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th>ทะเบียนรถ</th>
                                    <th>รายการ</th>
                                    <th>วันที่ซ่อมล่าสุด</th>
                                    <th>กำหนดถัดไป (กม. / วันที่)</th>
                                    <th>สถานะ</th>
                                    <th>จัดการ</th>
                                </tr>
                            </thead>
                            <tbody id="maintenance-list-body">
                                <tr>
                                    <td>6W-8492</td>
                                    <td>เปลี่ยนน้ำมันเครื่อง</td>
                                    <td>15/02/2026</td>
                                    <td>50,000 กม. / 15/08/2026</td>
                                    <td><span class="badge" style="background: rgba(16, 185, 129, 0.2); color: #10b981;">ปกติ</span></td>
                                    <td><button class="btn-icon text-accent"><i class="fa-solid fa-pen-to-square"></i></button></td>
                                </tr>
                                <tr>
                                    <td>4W-1122</td>
                                    <td>ตรวจเช็คระบบเบรก</td>
                                    <td>10/01/2026</td>
                                    <td>35,000 กม. / 10/07/2026</td>
                                    <td><span class="badge" style="background: rgba(245, 158, 11, 0.2); color: #f59e0b;">ใกล้ถึงกำหนด</span></td>
                                    <td><button class="btn-icon text-accent"><i class="fa-solid fa-pen-to-square"></i></button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <section id="fuel" class="view-section glass-panel">
                    <h3 class="section-subtitle mb-4"><i class="fa-solid fa-gas-pump text-accent"></i> การจัดการน้ำมัน (Fuel Management)</h3>
                    <div class="flex-between mb-4">
                        <p class="text-secondary">บันทึกและติดตามการใช้พลังงาน</p>
                        <button class="btn btn-primary btn-sm" id="btn-add-fuel-log"><i class="fa-solid fa-plus"></i> บันทึกการเติมน้ำมัน</button>
                    </div>

                    <div class="table-container">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th>วันที่</th>
                                    <th>ทะเบียนรถ</th>
                                    <th>ชนิดน้ำมัน</th>
                                    <th>จำนวน (ลิตร)</th>
                                    <th>ยอดเงิน (บาท)</th>
                                    <th>เลขไมล์ล่าสุด</th>
                                    <th>จัดการ</th>
                                </tr>
                            </thead>
                            <tbody id="fuel-log-body">
                                <tr>
                                    <td>20/03/2026</td>
                                    <td>6W-8492</td>
                                    <td>ดีเซล</td>
                                    <td>120.50</td>
                                    <td>4,200</td>
                                    <td>42,500</td>
                                    <td><button class="btn-icon text-danger"><i class="fa-solid fa-trash"></i></button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>
        </main>
    </div>
    <!-- Google Map Modal -->
    <div id="map-modal" class="modal-overlay">
        <div class="modal-content glass-panel">
            <div class="modal-header">
                <h3><i class="fa-solid fa-map-location-dot"></i> เลือกสถานที่บนแผนที่</h3>
                <button type="button" class="btn-close-modal" id="btn-close-map"><i class="fa-solid fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="map-search-bar mb-3">
                    <label>ค้นหาสถานที่ที่ปักหมุดไว้</label>
                    <div class="input-with-action">
                        <input type="text" id="map-search-input" placeholder="ค้นหาสถานที่ยอดนิยม..." style="flex-grow: 1;">
                        <button type="button" class="btn btn-primary" id="btn-search-location"><i class="fa-solid fa-magnifying-glass"></i> ค้นหา</button>
                    </div>
                </div>
                
                <div class="mb-3">
                    <label>หรือ ระบุจุดที่ไม่ได้ปักหมุด (Custom Location)</label>
                    <div class="input-with-action">
                        <input type="text" id="map-custom-input" placeholder="พิมพ์ชื่อสถานที่ที่ต้องการ (เช่น ปากซอยสุขุมวิท 101)..." style="flex-grow: 1;">
                        <button type="button" class="btn btn-secondary" id="btn-use-custom-location"><i class="fa-solid fa-thumbtack"></i> ใช้จุดนี้</button>
                    </div>
                </div>

                <!-- Search Results Suggestion List -->
                <div id="map-search-results" class="search-results-list" style="max-height: 150px; overflow-y: auto;">
                    <!-- Items inserted via JS -->
                </div>
                <!-- Interactive Leaflet Map for Location Selection -->
                <div class="map-container">
                    <div id="location-picker-map" style="width: 100%; height: 400px; border-radius: 8px; z-index: 1; background: #e5e7eb;"></div>
                </div>
            </div>
            <div class="modal-footer mt-4 flex-between">
                <div class="selected-location-text text-secondary">สถานที่จำลอง: <strong id="mock-location-name">สวนลุมพินี (Lumphini Park)</strong></div>
                <button type="button" class="btn btn-primary" id="btn-confirm-map"><i class="fa-solid fa-check"></i> ยืนยันสถานที่นี้</button>
            </div>
        </div>
    </div>

    <!-- Dashboard Vehicle Detail Modal -->
    <div id="vehicle-detail-modal" class="modal-overlay">
        <div class="modal-content glass-panel" style="max-width: 500px;">
            <div class="modal-header">
                <h3><i class="fa-solid fa-circle-info text-accent"></i> รายละเอียดการเดินทาง (Journey Details)</h3>
                <button class="btn-icon text-muted" id="btn-close-vehicle-modal"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body" id="vehicle-detail-content">
                <!-- Content injected via JS -->
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="js/modules/api.js?v=1"></script>
    <script src="js/app.js?v=6"></script>
</body>
</html>
